{
  "name": "accordagents",
  "productName": "AccordAgents",
  "version": "1.5.0",
  "private": true,
  "description": "Desktop app for multi-participant AI chat that debates a question or code diff and converges on a consensus answer.",
  "license": "Apache-2.0",
  "repository": "https://github.com/juliakrivchikova/AccordAgents-desktop-app.git",
  "main": "dist/main/main/main.js",
  "scripts": {
    "build": "npm run build:main && vite build",
    "build:main": "tsc -p tsconfig.main.json && node scripts/copy-main-assets.mjs",
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && npm run build:main && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "package": "npm run build && electron-forge package",
    "make": "npm run build && electron-forge make",
    "make:mac-arm64": "npm run make -- --platform=darwin --arch=arm64",
    "signed:mac-arm64": "node scripts/signed-mac-arm64.mjs",
    "start": "npm run build && electron .",
    "test:app-skills": "npm run build:main && node --test dist/main/main/services/appSkills.test.js",
    "test:command": "npm run build:main && node --test dist/main/main/services/command.test.js",
    "test:file-opener": "npm run build:main && node --test dist/main/main/services/intellijLauncher.test.js dist/main/main/services/localFileOpener.test.js dist/main/main/services/settings.repoFileOpenAction.test.js",
    "test:links": "npm run build:main && node --test dist/main/main/services/externalLinks.test.js dist/main/main/services/markdownInline.test.js",
    "test:settings": "npm run build:main && node --test dist/main/main/services/settings.behaviorRules.test.js dist/main/main/services/settings.roleArchive.test.js dist/main/main/services/settings.savedPrompts.test.js dist/main/main/services/settings.agentEnvironment.test.js dist/main/main/services/slashSuggestions.test.js",
    "test:agent-env": "npm run build:main && node --test dist/main/main/services/settings.agentEnvironment.test.js dist/main/main/services/toolchainRequirements.test.js dist/main/main/services/remoteRuns.test.js dist/main/main/services/cliAgents.permissions.test.js",
    "test:storage": "npm run build:main && node --test dist/main/main/services/storage.messages.test.js",
    "test:activity": "npm run build:main && node --test dist/main/main/services/chatActivity.test.js dist/main/main/services/chatActivityFocus.test.js dist/main/main/services/storage.activity.test.js && node --test scripts/activity-focus-contract.test.mjs",
    "test:chat-compact": "npm run build:main && node --test dist/main/main/services/chat.compact.test.js dist/main/main/services/chatParticipantStatus.test.js dist/main/main/services/chatRosterStatus.test.js",
    "test:user-skills": "npm run build:main && node --test dist/main/main/services/userSkills.test.js dist/main/main/services/chat.userSkills.test.js",
    "test:plugins": "npm run build:main && node --test dist/main/main/services/plugins.test.js",
    "test:accord": "npm run build:main && node --test dist/main/main/services/accordLauncherPreferences.test.js",
    "test:avatar-contract": "node --test scripts/avatar-contract.test.mjs",
    "test:member-copy": "node --test scripts/member-copy-guard.test.mjs",
    "test:permissions": "npm run build:main && node --test dist/main/main/services/chat.permissions.test.js dist/main/main/services/chat.rendererStreaming.test.js dist/main/main/services/toolchainRequirements.test.js dist/main/main/services/remoteRuns.test.js dist/main/main/services/cloudRunAws.test.js dist/main/main/services/cloudRunDoctor.test.js dist/main/main/services/awsWorkerKeyMaterial.test.js dist/main/main/services/awsWorkerLifecycle.test.js dist/main/main/services/chat.roleArchive.test.js dist/main/main/services/chat.repoFileMentions.test.js dist/main/main/services/repoFile.test.js dist/main/main/services/chat.participantRequestThreads.test.js dist/main/main/services/chat.rename.test.js dist/main/main/services/git.repoFiles.test.js dist/main/main/services/cliAgents.permissions.test.js dist/main/main/services/warnings.test.js",
    "lint:renderer-styles": "node scripts/check-renderer-style-guardrails.mjs",
    "lint:renderer-line-counts": "node scripts/check-renderer-line-counts.mjs",
    "lint:renderer-orphans": "node scripts/check-renderer-orphans.mjs",
    "lint:renderer-unused": "npm run lint:renderer-unused:locals && npm run lint:renderer-orphans",
    "lint:renderer-unused:locals": "tsc --noEmit -p tsconfig.renderer.json --noUnusedLocals --noUnusedParameters false",
    "typecheck": "tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.main.json",
    "release:patch": "node scripts/release-mac-arm64.mjs patch",
    "release:minor": "node scripts/release-mac-arm64.mjs minor",
    "release:major": "node scripts/release-mac-arm64.mjs major",
    "bump:patch": "node scripts/bump-version.mjs patch",
    "bump:minor": "node scripts/bump-version.mjs minor",
    "bump:major": "node scripts/bump-version.mjs major",
    "tag-release": "node scripts/tag-release.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.1079.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/hanken-grotesk": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@smithy/node-http-handler": "^4.9.2",
    "@tanstack/react-virtual": "^3.13.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.468.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "update-electron-app": "^3.2.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^20.11.30",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "shadcn": "^4.7.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0",
    "ws": "^8.20.1"
  },
  "config": {
    "forge": "./forge.config.ts",
    "releaseRepo": "juliakrivchikova/AccordAgents-Releases"
  }
}
