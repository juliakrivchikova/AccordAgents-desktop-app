{
  "name": "accordagents",
  "productName": "AccordAgents",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop app for multi-model review, debate, and consensus.",
  "repository": "https://github.com/juliakrivchikova/accordagents.git",
  "main": "dist/main/main/main.js",
  "scripts": {
    "build": "npm run build:main && vite build",
    "build:main": "tsc -p tsconfig.main.json && node scripts/copy-main-assets.mjs",
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && npm run build:main && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "package": "npm run build && electron-forge package",
    "make": "npm run build && electron-forge make",
    "make:mac-arm64": "npm run make -- --platform=darwin --arch=arm64",
    "signed:mac-arm64": "node scripts/signed-mac-arm64.mjs",
    "start": "npm run build && electron .",
    "test:app-skills": "npm run build:main && node --test dist/main/main/services/appSkills.test.js",
    "test:user-skills": "npm run build:main && node --test dist/main/main/services/userSkills.test.js dist/main/main/services/chat.userSkills.test.js",
    "test:permissions": "npm run build:main && node --test dist/main/main/services/chat.permissions.test.js dist/main/main/services/chat.repoFileMentions.test.js dist/main/main/services/chat.rename.test.js dist/main/main/services/git.repoFiles.test.js dist/main/main/services/cliAgents.permissions.test.js",
    "lint:renderer-styles": "node scripts/check-renderer-style-guardrails.mjs",
    "lint:renderer-orphans": "node scripts/check-renderer-orphans.mjs",
    "lint:renderer-unused": "npm run lint:renderer-unused:locals && npm run lint:renderer-orphans",
    "lint:renderer-unused:locals": "tsc --noEmit -p tsconfig.renderer.json --noUnusedLocals --noUnusedParameters false",
    "typecheck": "tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.main.json",
    "bump:patch": "node scripts/bump-version.mjs patch",
    "bump:minor": "node scripts/bump-version.mjs minor",
    "bump:major": "node scripts/bump-version.mjs major",
    "tag-release": "node scripts/tag-release.mjs"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@tanstack/react-virtual": "^3.13.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.468.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "update-electron-app": "^3.2.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^20.11.30",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0",
    "ws": "^8.20.1"
  },
  "config": {
    "forge": "./forge.config.ts"
  }
}
