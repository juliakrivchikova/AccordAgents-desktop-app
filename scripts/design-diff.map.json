{
  "$comment": "Per-component selector map for scripts/design-diff.cjs. 'design' selectors target the handoff bundle (classes are .aa-*); 'app' selectors target the live renderer (its own classes). The engine compares the COMPUTED STYLE of one representative element per type; it never compares text or the NUMBER of repeated items (rows/chips/pills) — content and counts are expected to differ and are ignored. Add components HERE, not in code. Match by role/structure, not shared class names.",
  "designDir": "../design_handoff_accordagents_chat",
  "appTitle": "AccordAgents",
  "components": {
    "provider-setup": {
      "designRoot": "div[style*=\"box-shadow: var(--shadow-md)\"]",
      "appRoot": ".cli-readiness-panel",
      "elements": [
        { "name": "panel",       "design": "div[style*=\"box-shadow: var(--shadow-md)\"]",                "app": ".cli-readiness-panel",                    "props": ["borderRadius", "backgroundColor", "borderColor", "boxShadow"] },
        { "name": "heading",     "design": ":scope > div:first-child",                                    "app": ".cli-readiness-heading",                  "props": ["padding", "gap"] },
        { "name": "headingTitle","design": ":scope > div:first-child > div:first-child > div:first-child", "app": ".cli-readiness-heading h2",               "props": ["fontSize", "fontWeight", "color"] },
        { "name": "headingCopy", "design": ":scope > div:first-child > div:first-child > div:nth-child(2)","app": ".cli-readiness-heading p",                "props": ["fontSize", "lineHeight", "color"] },
        { "name": "refresh",     "design": ":scope > div:first-child > button",                           "app": ".cli-readiness-heading .cli-readiness-secondary", "props": ["borderRadius", "padding", "gap", "fontSize", "fontWeight", "backgroundColor", "color"] },
        { "name": "list",        "design": ":scope > div:nth-child(2)",                                    "app": ".cli-readiness-grid",                     "props": ["padding", "gap"] },
        { "name": "row",         "design": ":scope > div:nth-child(2) > div:nth-child(2)",                 "app": ".cli-readiness-card.is-claude-code",      "props": ["borderRadius", "backgroundColor", "borderColor"] },
        { "name": "rowHeader",   "design": ":scope > div:nth-child(2) > div:nth-child(2) > div:first-child","app": ".cli-readiness-card.is-claude-code .cli-readiness-card-header", "props": ["padding", "gap"] },
        { "name": "icon",        "design": ":scope > div:nth-child(2) > div:nth-child(2) > div:first-child > span:first-child", "app": ".cli-readiness-card.is-claude-code .cli-readiness-provider-icon", "props": ["width", "height", "borderRadius", "backgroundColor"] },
        { "name": "rowTitle",    "design": ":scope > div:nth-child(2) > div:nth-child(2) h3, :scope > div:nth-child(2) > div:nth-child(2) div[style*=\"font-size: 14px\"]", "app": ".cli-readiness-card.is-claude-code h3", "props": ["fontSize", "fontWeight", "color"] },
        { "name": "status",      "design": ":scope > div:nth-child(2) > div:nth-child(2) > div:first-child > div:nth-child(2) > div:nth-child(2)", "app": ".cli-readiness-card.is-claude-code .cli-readiness-status", "props": ["gap"] },
        { "name": "statusText",  "design": ":scope > div:nth-child(2) > div:nth-child(2) > div:first-child > div:nth-child(2) > div:nth-child(2) > span:nth-child(2)", "app": ".cli-readiness-card.is-claude-code .cli-readiness-status > span:nth-child(2)", "props": ["fontSize", "color"] },
        { "name": "statusStrong","design": ":scope > div:nth-child(2) > div:nth-child(2) > div:first-child > div:nth-child(2) > div:nth-child(2) > span:nth-child(2) > span", "app": ".cli-readiness-card.is-claude-code .cli-readiness-status strong", "props": ["color", "fontWeight"] },
        { "name": "toggle",      "design": ":scope > div:nth-child(2) > div:nth-child(2) > div:first-child button", "app": ".cli-readiness-card.is-claude-code .cli-readiness-toggle", "props": ["width", "height", "borderRadius", "backgroundColor", "color"] },
        { "name": "steps",       "design": ":scope > div:nth-child(2) > div:nth-child(2) > div:nth-child(2)", "app": ".cli-readiness-card.is-claude-code .cli-readiness-steps", "props": ["padding", "gap", "backgroundColor", "borderColor"] },
        { "name": "step",        "design": ":scope > div:nth-child(2) > div:nth-child(2) > div:nth-child(2) > div:first-child", "app": ".cli-readiness-card.is-claude-code .cli-readiness-step", "props": ["gap"] },
        { "name": "stepNumber",  "design": ":scope > div:nth-child(2) > div:nth-child(2) > div:nth-child(2) > div:first-child > span:first-child", "app": ".cli-readiness-card.is-claude-code .cli-readiness-step-number", "props": ["width", "height", "borderRadius", "fontSize", "fontWeight", "backgroundColor", "color"] },
        { "name": "stepText",    "design": ":scope > div:nth-child(2) > div:nth-child(2) > div:nth-child(2) > div:first-child > span:nth-child(2)", "app": ".cli-readiness-card.is-claude-code .cli-readiness-step > span:nth-child(2)", "props": ["fontSize", "color"] },
        { "name": "command",     "design": ":scope > div:nth-child(2) > div:nth-child(2) > div:nth-child(2) > div:nth-child(3)", "app": ".cli-readiness-card.is-claude-code .cli-readiness-command", "props": ["padding", "gap", "borderRadius", "backgroundColor", "borderColor"] },
        { "name": "code",        "design": ":scope > div:nth-child(2) > div:nth-child(2) > div:nth-child(2) > div:nth-child(3) > span:first-child", "app": ".cli-readiness-card.is-claude-code .cli-readiness-command code", "props": ["fontSize", "color"] },
        { "name": "copyButton",  "design": ":scope > div:nth-child(2) > div:nth-child(2) > div:nth-child(2) > div:nth-child(3) button", "app": ".cli-readiness-card.is-claude-code .cli-readiness-command button", "props": ["width", "height", "borderRadius", "backgroundColor", "color"] },
        { "name": "note",        "design": ":scope > div:last-child",                                      "app": ".cli-readiness-note",                      "props": ["padding", "gap", "borderColor"] },
        { "name": "noteText",    "design": ":scope > div:last-child > span",                               "app": ".cli-readiness-note > span",               "props": ["fontSize", "lineHeight", "color"] }
      ],
      "fixtureHtml": "<section class=\"cli-readiness-panel\"><div class=\"cli-readiness-heading\"><div><h2>Connect a CLI provider</h2><p>AccordAgents uses a CLI you've already installed and signed in on this Mac.</p></div><button class=\"cli-readiness-secondary\">Check again</button></div><div class=\"cli-readiness-grid\"><article class=\"cli-readiness-card is-claude-code is-expanded\"><div class=\"cli-readiness-card-header\"><span class=\"cli-readiness-provider-icon\"></span><div class=\"cli-readiness-provider-copy\"><h3>Claude Code</h3><span class=\"cli-readiness-status is-sign-in-required\"><span class=\"cli-readiness-status-dot\"></span><span>Installed · sign-in required</span></span></div><button class=\"cli-readiness-toggle\"></button></div><div class=\"cli-readiness-steps\"><div class=\"cli-readiness-step\"><span class=\"cli-readiness-step-number\">1</span><span>Install the CLI in Terminal</span></div><div class=\"cli-readiness-step\"><span class=\"cli-readiness-step-number\">2</span><span>Sign in from Terminal</span></div><div class=\"cli-readiness-command\"><code><span>$</span> claude auth login</code><button></button></div><div class=\"cli-readiness-detail-actions\"><button class=\"cli-readiness-detail-action\">Open Terminal</button><button class=\"cli-readiness-detail-action\">Official guide</button></div></div></article></div><p class=\"cli-readiness-note\">Commands are copied only when you choose <strong>Copy</strong>. AccordAgents never installs software or signs in for you.</p></section>"
    },
    "choice-card": {
      "designFile": "AccordAgents Chat (standalone).html",
      "designRoot": ".aa-perm",
      "appRoot": ".chat-choice-card",
      "elements": [
        { "name": "panel",       "design": ".aa-perm",            "app": ".chat-choice-card",                "props": ["borderRadius", "padding", "gap", "backgroundColor"] },
        { "name": "option",      "design": ".aa-perm-opt",        "app": ".chat-choice-option",              "props": ["borderRadius", "padding", "gap"] },
        { "name": "optionSelBg", "design": ".aa-perm-opt.is-sel", "app": ".chat-choice-option.selected",     "props": ["backgroundColor"] },
        { "name": "optionLabel", "design": ".aa-perm-label",      "app": ".chat-choice-option-title strong", "props": ["fontSize", "fontWeight", "color"] },
        { "name": "submit",      "design": ".aa-perm-submit",     "app": ".chat-choice-submit",              "props": ["backgroundColor", "color", "borderRadius", "fontSize"], "composed": true }
      ],
      "fixtureHtml": "<section class=\"chat-choice-card\" aria-label=\"T\"><div class=\"chat-choice-head\"><div class=\"chat-choice-title-block\"><h3>Which automation to build</h3><p class=\"chat-choice-question\">How far do you want the design-diff to go?</p></div></div><div class=\"chat-choice-options\" role=\"radiogroup\"><label class=\"chat-choice-option selected\"><input type=\"radio\" checked><span class=\"chat-choice-num\">1.</span><span class=\"chat-choice-option-body\"><span class=\"chat-choice-option-title\"><strong>Option A</strong><small class=\"chat-choice-recommended-chip\">Recommended</small></span><span class=\"chat-choice-option-description\">vision self-check skill</span></span></label><label class=\"chat-choice-option\"><input type=\"radio\"><span class=\"chat-choice-num\">2.</span><span class=\"chat-choice-option-body\"><span class=\"chat-choice-option-title\"><strong>Option B</strong></span><span class=\"chat-choice-option-description\">computed-style diff</span></span></label></div><div class=\"chat-choice-actions\"><div class=\"chat-choice-action-buttons\"><button class=\"chat-choice-cancel\">Cancel</button><button class=\"chat-choice-submit\"><span>Submit</span><kbd>↵</kbd></button></div></div></section>"
    },
    "review-card": {
      "designFile": "Review Card (standalone) (1).html",
      "designRoot": ".aa-rev",
      "appRoot": ".chat-app-tool-approval-panel.is-review-change",
      "$elementsComment": "Elements with both design+app are style-compared. Elements with only `app` are impl-only (expect ABSENT IN DESIGN — impl added it). Elements with only `design` are design-only (expect ABSENT IN IMPL — impl dropped it).",
      "elements": [
        { "name": "panel",         "design": ".aa-rev",          "app": ".chat-app-tool-approval-panel.is-review-change",                                "props": ["borderRadius", "backgroundColor", "borderColor"] },
        { "name": "chip",          "design": ".aa-rev-badge",    "app": ".chat-app-tool-review-chip",                                                    "props": ["borderRadius", "padding", "gap", "fontSize", "fontWeight", "backgroundColor"] },
        { "name": "roleNameInput", "design": ".aa-rev-input",    "app": ".chat-app-tool-review-block.is-role-review .chat-app-tool-review-field input",   "props": ["borderRadius", "padding", "fontSize", "color", "backgroundColor", "borderColor"] },
        { "name": "footer",        "design": ".aa-rev-foot",     "app": ".chat-app-tool-review-footer",                                                  "props": ["padding", "gap", "backgroundColor", "borderColor"] },
        { "name": "submit",        "design": ".aa-btn-primary",  "app": ".chat-app-tool-review-submit",                                                  "props": ["borderRadius", "fontSize", "backgroundColor", "color"], "composed": true },

        { "name": "titleBlock",    "app": ".chat-app-tool-review-role-head",                                                                            "props": [] },
        { "name": "specPanel",     "app": ".chat-app-tool-review-spec",                                                                                 "props": [] },
        { "name": "specRow",       "app": ".chat-app-tool-review-spec-row",                                                                             "props": [] },

        { "name": "description",   "design": ".aa-rev-textarea", "app": ".chat-app-tool-review-field.is-description textarea", "props": [] },
        { "name": "charCount",     "design": ".aa-rev-count",    "app": ".chat-app-tool-review-field.is-role-name em",         "props": [] },
        { "name": "previewToggle", "design": ".aa-rev-seg",      "app": ".chat-app-tool-review-preview-toggle",                "props": [] }
      ],
      "fixtureHtml": "<section class=\"chat-app-tool-approval-panel is-review-change\" aria-label=\"Chat Assistant wants to create a role\"><div class=\"chat-app-tool-review-chip\">New role</div><h3>@assistant wants to create a role</h3><fieldset class=\"chat-app-tool-review-fieldset\"><div class=\"chat-app-tool-review-stack\"><div class=\"chat-app-tool-review-block is-role-review is-new-role\"><div class=\"chat-app-tool-review-role-head\"><div class=\"chat-app-tool-review-role-icon\" aria-hidden=\"true\"></div><div><strong>Performance auditor</strong><span>Reusable role template</span></div></div><div class=\"chat-app-tool-review-spec\"><div class=\"chat-app-tool-review-spec-row\"><span>Role type</span><strong>Custom role</strong></div><div class=\"chat-app-tool-review-spec-row\"><span>App tools</span><strong>No app tool grants</strong></div></div><label class=\"chat-app-tool-review-field\"><span>Role name</span><input value=\"Performance auditor\"></label><label class=\"chat-app-tool-review-field is-instructions\"><span><span>Instructions</span><em>28 words</em></span><textarea rows=\"7\">Review performance-sensitive code changes. Focus on avoidable regressions, missing measurements, and risky runtime behavior. Keep findings concrete and tied to files.</textarea></label></div></div></fieldset><div class=\"chat-app-tool-review-footer\"><button class=\"chat-app-tool-review-cancel\">Cancel</button><button class=\"chat-app-tool-review-submit\" data-slot=\"button\">Create role</button></div></section>"
    }
  }
}
